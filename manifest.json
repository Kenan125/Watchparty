{
  "manifest_version": 3,
  "name": "Crunchyroll WatchParty",
  "description": "Create watch parties on Crunchyroll with synced playback, chat, and event logs.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://www.crunchyroll.com/*", "https://beta.crunchyroll.com/*"],
  "action": {
    "default_title": "WatchParty",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.crunchyroll.com/*", "https://beta.crunchyroll.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}